<Window x:Class="CityAppealsApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CityAppealsApp.ViewModels"
        Title="Учёт обращений граждан" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="LightGray" Margin="0,0,0,5">
            <TextBlock Text="{Binding UserInfo}" Margin="10,5" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Выход" Command="{Binding LogoutCommand}" Margin="10,5" Padding="5,2"/>
        </StackPanel>
        <ContentControl Name="ActiveControl" DockPanel.Dock="Bottom"/>
    </DockPanel>
</Window>