<Window
    x:Class="CityAppealsApp.Views.CreateAppealWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:CityAppealsApp.ViewModels"
    Title="Новое обращение"
    Width="520"
    Height="450"
    WindowStartupLocation="CenterOwner">
    <Window.DataContext>
        <vm:CreateAppealViewModel />
    </Window.DataContext>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock VerticalAlignment="Center" Text="Категория *:" />
        <ComboBox
            Grid.Column="1"
            Margin="5"
            DisplayMemberPath="Name"
            ItemsSource="{Binding Categories}"
            SelectedItem="{Binding SelectedCategory}" />

        <TextBlock
            Grid.Row="1"
            VerticalAlignment="Center"
            Text="Заголовок *:" />
        <TextBox
            Grid.Row="1"
            Grid.Column="1"
            Margin="5"
            MaxLength="200"
            Text="{Binding Title}" />

        <TextBlock
            Grid.Row="2"
            Margin="0,5,0,0"
            VerticalAlignment="Top"
            Text="Описание:" />
        <TextBox
            Grid.Row="2"
            Grid.Column="1"
            Height="80"
            Margin="5"
            AcceptsReturn="True"
            MaxLength="4000"
            Text="{Binding Description}"
            TextWrapping="Wrap" />

        <TextBlock
            Grid.Row="3"
            Margin="0,5"
            VerticalAlignment="Top"
            Text="Вложения:" />
        <StackPanel
            Grid.Row="3"
            Grid.Column="1"
            Margin="5">
            <Button
                Margin="0,0,0,5"
                HorizontalAlignment="Left"
                Command="{Binding AddFileCommand}"
                Content="Добавить файл" />
            <ListBox Height="60" ItemsSource="{Binding TempFiles}" />
        </StackPanel>

        <Button
            Grid.Row="4"
            Grid.ColumnSpan="2"
            Margin="10"
            HorizontalAlignment="Center"
            Command="{Binding CreateCommand}"
            Content="Создать" />
    </Grid>
</Window>