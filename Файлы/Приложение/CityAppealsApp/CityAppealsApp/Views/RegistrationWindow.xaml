<Window
    x:Class="CityAppealsApp.Views.RegistrationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:CityAppealsApp.ViewModels"
    Title="Регистрация гражданина"
    Width="380"
    Height="480"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <Window.DataContext>
        <vm:RegistrationViewModel />
    </Window.DataContext>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock
            Margin="0,5"
            VerticalAlignment="Center"
            Text="Логин *:" />
        <TextBox
            Grid.Column="1"
            Margin="5,5,0,5"
            MaxLength="50"
            Text="{Binding Login}" />

        <TextBlock
            Grid.Row="1"
            Margin="0,5"
            VerticalAlignment="Center"
            Text="Пароль *:" />
        <PasswordBox
            Name="PasswordBox"
            Grid.Row="1"
            Grid.Column="1"
            Margin="5,5,0,5"
            MaxLength="50" />

        <TextBlock
            Grid.Row="2"
            Margin="0,5"
            VerticalAlignment="Center"
            Text="Подтверждение *:" />
        <PasswordBox
            Name="ConfirmPasswordBox"
            Grid.Row="2"
            Grid.Column="1"
            Margin="5,5,0,5"
            MaxLength="50" />

        <TextBlock
            Grid.Row="3"
            Margin="0,5"
            VerticalAlignment="Center"
            Text="Email:" />
        <TextBox
            Grid.Row="3"
            Grid.Column="1"
            Margin="5,5,0,5"
            MaxLength="100"
            Text="{Binding Email}" />

        <TextBlock
            Grid.Row="4"
            Margin="0,5"
            VerticalAlignment="Center"
            Text="Телефон:" />
        <TextBox
            Grid.Row="4"
            Grid.Column="1"
            Margin="5,5,0,5"
            MaxLength="20"
            Text="{Binding Phone}" />

        <TextBlock
            Grid.Row="5"
            Margin="0,5"
            VerticalAlignment="Center"
            Text="ФИО *:" />
        <TextBox
            Grid.Row="5"
            Grid.Column="1"
            Margin="5,5,0,5"
            MaxLength="100"
            Text="{Binding FullName}" />

        <TextBlock
            Grid.Row="6"
            Margin="0,5"
            VerticalAlignment="Center"
            Text="Адрес:" />
        <TextBox
            Grid.Row="6"
            Grid.Column="1"
            Margin="5,5,0,5"
            MaxLength="200"
            Text="{Binding Address}" />

        <Button
            Grid.Row="7"
            Grid.ColumnSpan="2"
            Margin="10"
            HorizontalAlignment="Center"
            Click="RegisterButton_Click"
            Command="{Binding RegisterCommand}"
            CommandParameter="{Binding ElementName=PasswordBox}"
            Content="Зарегистрироваться" />
    </Grid>
</Window>