<UserControl
    x:Class="CityAppealsApp.Views.AdminView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:CityAppealsApp.Converters"
    xmlns:vm="clr-namespace:CityAppealsApp.ViewModels">
    <UserControl.DataContext>
        <vm:AdminViewModel />
    </UserControl.DataContext>
    <UserControl.Resources>
        <converters:BoolToActiveConverter x:Key="BoolToActive" />
    </UserControl.Resources>
    <TabControl Margin="10">
        <TabItem Header="Пользователи">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <GroupBox
                    Margin="5"
                    Padding="5"
                    Header="Добавить пользователя">
                    <StackPanel>
                        <StackPanel Margin="0,2" Orientation="Horizontal">
                            <TextBlock
                                Width="80"
                                VerticalAlignment="Center"
                                Text="Логин *:" />
                            <TextBox
                                Width="150"
                                MaxLength="50"
                                Text="{Binding NewLogin}" />
                            <TextBlock
                                Width="60"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Text="Пароль *:" />
                            <TextBox
                                Width="150"
                                MaxLength="50"
                                Text="{Binding NewPassword}" />
                        </StackPanel>
                        <StackPanel Margin="0,2" Orientation="Horizontal">
                            <TextBlock
                                Width="80"
                                VerticalAlignment="Center"
                                Text="ФИО *:" />
                            <TextBox
                                Width="200"
                                MaxLength="100"
                                Text="{Binding NewFullName}" />
                            <TextBlock
                                Width="40"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Text="Роль *:" />
                            <ComboBox
                                Width="150"
                                ItemsSource="{Binding Roles}"
                                SelectedItem="{Binding NewRole}" />
                        </StackPanel>
                        <StackPanel Margin="0,2" Orientation="Horizontal">
                            <TextBlock
                                Width="80"
                                VerticalAlignment="Center"
                                Text="Отдел:" />
                            <TextBox
                                Width="150"
                                MaxLength="100"
                                Text="{Binding NewDepartment}" />
                            <TextBlock
                                Width="70"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Text="Должность:" />
                            <TextBox
                                Width="150"
                                MaxLength="100"
                                Text="{Binding NewPosition}" />
                        </StackPanel>
                        <Button
                            Width="140"
                            Margin="0,5"
                            Command="{Binding RegisterUserCommand}"
                            Content="Зарегистрировать" />
                    </StackPanel>
                </GroupBox>
                <StackPanel
                    Grid.Row="1"
                    Margin="5"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,5,0"
                        VerticalAlignment="Center"
                        Text="Поиск:" />
                    <TextBox
                        Width="200"
                        Margin="0,0,5,0"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        Width="70"
                        Command="{Binding SearchCommand}"
                        Content="Найти" />
                    <Button
                        Width="90"
                        Margin="5,0,0,0"
                        Command="{Binding RefreshUsersCommand}"
                        Content="Обновить" />
                </StackPanel>
                <DataGrid
                    Grid.Row="3"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    ItemsSource="{Binding Users}"
                    SelectedItem="{Binding SelectedUser}">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="50"
                            Binding="{Binding UserID}"
                            Header="ID" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Login}"
                            Header="Логин" />
                        <DataGridTextColumn
                            Width="200"
                            Binding="{Binding FullName}"
                            Header="ФИО" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Role}"
                            Header="Роль" />
                        <DataGridTemplateColumn Width="70" Header="Активен">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding IsActive, Converter={StaticResource BoolToActive}}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="154">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button
                                        Width="150"
                                        Command="{Binding DataContext.ToggleActiveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Content="Сменить активность" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>